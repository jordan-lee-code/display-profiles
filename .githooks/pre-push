#!/bin/bash
# Pre-push hook: prompt for a semver bump and publish a GitHub release
# whenever commits are pushed to main.
#
# Stored in .githooks/ and activated by install.sh via:
#   git config core.hooksPath .githooks
#
# Requires the GitHub CLI (gh) to be installed and authenticated.

# pre-push receives "local_ref local_sha remote_ref remote_sha" on stdin,
# one line per ref being pushed.
while read -r local_ref local_sha remote_ref remote_sha; do
    [[ "$remote_ref" == "refs/heads/main" ]] || continue

    # Find the latest semver tag. Defaults to v0.0.0 if no tags exist yet.
    LATEST=$(git tag --sort=-version:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -1)
    LATEST="${LATEST:-v0.0.0}"

    # Parse into components for arithmetic.
    version="${LATEST#v}"
    major="${version%%.*}"; rest="${version#*.}"
    minor="${rest%%.*}"; patch="${rest#*.}"

    echo ""
    echo "Pushing to main. Current version: $LATEST"
    echo ""
    echo "Select version bump:"
    echo "  1. patch  ->  v$major.$minor.$((patch+1))  (bug fixes, comments, docs)"
    echo "  2. minor  ->  v$major.$((minor+1)).0        (new features, backwards compatible)"
    echo "  3. major  ->  v$((major+1)).0.0              (breaking changes)"
    echo "  4. skip   — push without creating a release"
    echo ""
    read -rp "  Choice [1]: " choice
    choice="${choice:-1}"

    case "$choice" in
        2) NEW_VER="v$major.$((minor+1)).0" ;;
        3) NEW_VER="v$((major+1)).0.0" ;;
        4) continue ;;
        *) NEW_VER="v$major.$minor.$((patch+1))" ;;
    esac

    # Auto-generate release notes from commit messages since the last tag.
    # Falls back to the full log if this is the first tag.
    if [[ "$LATEST" == "v0.0.0" ]]; then
        NOTES=$(git log --pretty=format:"- %s" | head -30)
    else
        NOTES=$(git log "${LATEST}..HEAD" --pretty=format:"- %s")
    fi

    if [[ -z "$NOTES" ]]; then
        NOTES="No changes recorded."
    fi

    echo ""
    echo "Creating release $NEW_VER..."

    # Create an annotated tag locally, push it, then publish the release.
    git tag -a "$NEW_VER" -m "$NEW_VER"
    git push origin "$NEW_VER"
    gh release create "$NEW_VER" --title "$NEW_VER" --notes "$NOTES"

    echo "Release $NEW_VER published."
done
